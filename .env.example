# PostgreSQL
POSTGRES_USER=web3agent
POSTGRES_PASSWORD=web3agent
POSTGRES_DB=web3agent
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ChromaDB
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# LLM Providers (API keys)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# LLM fallback priority (comma-separated: deepseek,qwen,gemini)
LLM_PROVIDER_PRIORITY=deepseek,qwen,gemini

# Slack
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=

# Security APIs
GOPLUS_API_KEY=
CERTIK_API_KEY=
SCAMSNIFFER_API_KEY=

# Search / discovery (Tavily — LLM-optimized web search)
GITHUB_TOKEN=
TAVILY_API_KEY=
DEFILLAMA_CHAINS_URL=https://api.llama.fi/v2/chains

# Twitter (Twikit)
TWITTER_AUTH_INFO_1=
TWITTER_AUTH_INFO_2=
TWITTER_PASSWORD=
TWITTER_TOTP_SECRET=
TWITTER_COOKIES_FILE=.twitter-cookies.json
SOCIAL_WATCH_INTERVAL_MINUTES=15
TWITTER_FETCH_COUNT=20

# Application
LOG_LEVEL=INFO
HEARTBEAT_INTERVAL_MINUTES=30
